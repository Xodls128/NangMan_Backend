SECRET_KEY=
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
# 로컬(development)은 SQLite 사용 — 아래 DB_* 는 production에서만 필요
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

# 프로덕션 예시 (EC2)
# DEBUG=False
# ALLOWED_HOSTS=api.gamemate.kr,gamemate.kr
# CSRF_TRUSTED_ORIGINS=https://api.gamemate.kr,https://gamemate.kr
# CORS_ALLOWED_ORIGINS=https://gamemate.kr,https://www.gamemate.kr
# REDIS_URL=redis://127.0.0.1:6379/0
# SECURE_SSL_REDIRECT=True

# MVP 테스트 모드 (기본 false)
# true면 카카오 로그인 API/UI를 끄고 닉네임·비밀번호 통합 가입/로그인을 사용합니다.
# 활성화 값은 true/1/yes/on 만 인식합니다. (TURE 등 오타는 비활성)
MVP_TEST=false

# 카카오 로그인 (콘솔 값과 Redirect URI 일치 필수)
# MVP_TEST=true 이면 카카오 키가 없어도 됩니다.
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:5173/auth/kakao/callback
# 프로덕션 예: KAKAO_REDIRECT_URI=https://gamemate.kr/auth/kakao/callback
