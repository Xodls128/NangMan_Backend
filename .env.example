# 프로젝트 루트 .env — docker compose가 web/db에 전달합니다.
# EC2: cp .env.example .env && nano .env

SECRET_KEY=CHANGE_ME_LONG_RANDOM_STRING
DEBUG=False

ALLOWED_HOSTS=api.gamemate.kr,gamemate.kr,www.gamemate.kr
CSRF_TRUSTED_ORIGINS=https://api.gamemate.kr,https://gamemate.kr,https://www.gamemate.kr
CORS_ALLOWED_ORIGINS=https://gamemate.kr,https://www.gamemate.kr

DB_NAME=nangman
DB_USER=nangman
DB_PASSWORD=CHANGE_ME_DB_PASSWORD
# compose의 web 서비스가 DB_HOST=db 로 덮어씁니다. 로컬 참고용:
DB_HOST=db
DB_PORT=5432

REDIS_URL=redis://redis:6379/0

# SSL 발급 전에는 False, certbot 완료 후 True
SECURE_SSL_REDIRECT=True

KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=https://gamemate.kr/auth/kakao/callback
